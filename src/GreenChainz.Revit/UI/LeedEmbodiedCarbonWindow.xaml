<Window x:Class="GreenChainz.Revit.UI.LeedEmbodiedCarbonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LEED v4.1 MRpc132 - Embodied Carbon - GreenChainz" Height="780" Width="980"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <StackPanel>
                <TextBlock Text="LEED v4.1 MRpc132 Pilot Credit" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Procurement of Low Carbon Construction Materials" FontSize="11" Foreground="#B7E4C7" Margin="0,2,0,0"/>
                <TextBlock x:Name="ProjectNameText" Text="Project Name" FontSize="11" Foreground="#B7E4C7"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Summary Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="6" Padding="14" Margin="0,0,8,0" x:Name="PointsBadge" Background="#2D6A4F">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Points Earned" FontSize="11" Foreground="#B7E4C7" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PointsText" Text="0/2" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="6" Background="#40916C" Padding="14" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Carbon Reduction" FontSize="11" Foreground="#B7E4C7" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ReductionText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="6" Background="#D8F3DC" Padding="14" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="bECIb (Baseline)" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="BaselineText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2D6A4F" HorizontalAlignment="Center"/>
                        <TextBlock Text="kgCO2e/sf" FontSize="10" Foreground="#6C757D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" CornerRadius="6" Background="#D8F3DC" Padding="14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="bECIa (Actual)" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ActualText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2D6A4F" HorizontalAlignment="Center"/>
                        <TextBlock Text="kgCO2e/sf" FontSize="10" Foreground="#6C757D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Credit Status -->
            <Border Grid.Row="1" Background="#D8F3DC" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Credit Status" FontWeight="SemiBold" FontSize="14" Foreground="#2D6A4F"/>
                    <TextBlock x:Name="StatusText" Text="Status" FontSize="12" Margin="0,4,0,0"/>
                    <TextBlock x:Name="RecommendationText" Text="Recommendation" FontSize="11" Foreground="#6C757D" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Material Breakdown -->
            <DockPanel Grid.Row="2">
                <TextBlock Text="Material Carbon Breakdown (per CLF v2021)" DockPanel.Dock="Top" Style="{StaticResource GcSectionHeader}"/>
                <DataGrid x:Name="MaterialsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DEE2E6"
                          RowBackground="White" AlternatingRowBackground="#F0F7F4"
                          BorderBrush="#DEE2E6" BorderThickness="1" FontSize="12" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2D6A4F"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderBrush" Value="#1B4332"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding MaterialCategory}" Width="120"/>
                        <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="*"/>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding QuantityDisplay}" Width="90"/>
                        <DataGridTextColumn Header="mECIb" Binding="{Binding BaselineECI, StringFormat=N1}" Width="70">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Baseline CO2" Binding="{Binding BaselineCarbonDisplay}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Actual CO2" Binding="{Binding ActualCarbonDisplay}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Reduction" Binding="{Binding PercentReduction, StringFormat={}{0:F1}%}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#2D6A4F"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EPD Source" Binding="{Binding EPDSource}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Totals -->
            <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="12" Margin="0,8,0,8" BorderBrush="#DEE2E6" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="TotalBaselineText" Text="Total Baseline: 0 kgCO2e" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="1" x:Name="TotalActualText" Text="Total Actual: 0 kgCO2e" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="BuildingAreaText" Text="Building Area: 0 sf" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Find EPDs (EC3)" Click="FindEPDs_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Export bECI Report" Click="ExportReport_Click" Style="{StaticResource GcPrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="Close" Click="Close_Click" Style="{StaticResource GcSecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
