<Window x:Class="GreenChainz.Revit.UI.CcpsScorecardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enterprise CCPS Scorecard - GreenChainz" Height="580" Width="480"
        MinHeight="450" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="MaterialNameText" Text="Material Name" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="CategoryText" Text="Category" FontSize="11" Foreground="#B7E4C7" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="16">
            <!-- Total CCPS Score -->
            <Border Background="#D8F3DC" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Total CCPS Score" FontSize="14" FontWeight="SemiBold" Foreground="#2D6A4F"/>
                        <TextBlock Text="Comprehensive Carbon Performance Score" FontSize="10" Foreground="#6C757D"/>
                    </StackPanel>
                    <TextBlock x:Name="TotalScoreText" Grid.Column="1" Text="85" FontSize="32" FontWeight="Bold" Foreground="#2D6A4F" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 6 Pillars Breakdown -->
            <TextBlock Text="6 Pillars Breakdown" Style="{StaticResource GcSectionHeader}"/>
            <ItemsControl x:Name="PillarsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="#1B1B1B"/>
                            <TextBlock Grid.Column="1" Text="{Binding Score}" FontWeight="Bold" FontSize="12" Foreground="#2D6A4F"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Value="{Binding Score}" Height="6" Margin="0,4,0,0"
                                         Foreground="{Binding Color}" Background="#DEE2E6"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Swap Suggestion -->
            <Border Background="#FFF8E1" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,16,0,16">
                <StackPanel>
                    <TextBlock Text="Better Swap Available" FontWeight="SemiBold" Foreground="#E65100" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SwapSuggestionText" Text="Loading swap candidates..." FontSize="11" TextWrapping="Wrap" Foreground="#1B1B1B"/>
                    <Button Content="View Swap Details" Margin="0,8,0,0" HorizontalAlignment="Left" Click="ViewSwap_Click"
                            Style="{StaticResource GcPrimaryButton}" Padding="12,6"/>
                </StackPanel>
            </Border>

            <Button Content="Close" HorizontalAlignment="Right" Click="Close_Click" Style="{StaticResource GcSecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
