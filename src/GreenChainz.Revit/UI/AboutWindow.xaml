<Window x:Class="GreenChainz.Revit.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About GreenChainz" Height="500" Width="500"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <StackPanel>
                <TextBlock Text="GreenChainz" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Sustainable Building Materials Platform" FontSize="11" Foreground="#B7E4C7" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16">
                <TextBlock x:Name="VersionText" Text="Version 1.0.0" FontSize="13" Foreground="#6C757D" Margin="0,0,0,16"/>

                <TextBlock Text="Features" Style="{StaticResource GcSectionHeader}"/>
                <Border Background="White" CornerRadius="6" Padding="12" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Carbon Audit with EC3 + CLF data" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="LEED v4.1 and v5 Credit Analysis" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="MRpc132 Embodied Carbon Calculator" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="Sustainable Supplier Database" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="Request for Quote (RFQ) System" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="IFC + BCF Export (openBIM)" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="PDF Report Export" FontSize="13" Margin="0,3"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Data Sources" Style="{StaticResource GcSectionHeader}"/>
                <Border Background="White" CornerRadius="6" Padding="12" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="EC3 Building Transparency API" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="CLF v2021 Baseline Factors" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="Autodesk Construction Cloud" FontSize="13" Margin="0,3"/>
                        <TextBlock Text="USGBC LEED Standards" FontSize="13" Margin="0,3"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="12" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Connection Status: " FontSize="13" Foreground="#6C757D"/>
                        <TextBlock x:Name="StatusText" Text="Checking..." FontSize="13" FontWeight="SemiBold" Foreground="#2D6A4F"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button Content="Visit Website" Click="OpenWebsite_Click" Style="{StaticResource GcPrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="EC3 Database" Click="OpenEC3_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="USGBC LEED" Click="OpenUSGBC_Click" Style="{StaticResource GcSecondaryButton}"/>
                </StackPanel>

                <Button Content="Close" IsCancel="True" Style="{StaticResource GcSecondaryButton}" HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
