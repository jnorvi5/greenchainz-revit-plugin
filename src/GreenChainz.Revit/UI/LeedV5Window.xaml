<Window x:Class="GreenChainz.Revit.UI.LeedV5Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LEED v5 BD+C Analysis - GreenChainz" Height="850" Width="1100"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <StackPanel>
                <TextBlock Text="LEED v5 BD+C: New Construction" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="ProjectNameText" Text="Project Name" FontSize="11" Foreground="#B7E4C7" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Summary Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="6" Padding="14" Margin="0,0,8,0" x:Name="CertBadge" Background="#2D6A4F">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Certification" FontSize="11" Foreground="#B7E4C7" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CertLevelText" Text="GOLD" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="6" Background="#40916C" Padding="14" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Points Earned" FontSize="11" Foreground="#B7E4C7" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PointsText" Text="0/110" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="6" Background="#D8F3DC" Padding="14" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Prerequisites" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PrereqText" Text="0/0" FontSize="24" FontWeight="Bold" Foreground="#2D6A4F" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" CornerRadius="6" Background="#D8F3DC" Padding="14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Score" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ScoreText" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#2D6A4F" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- TabControl -->
            <TabControl Grid.Row="1" Margin="0,0,0,12" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,8"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="All Credits">
                    <DataGrid x:Name="CreditsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DEE2E6"
                              RowBackground="White" AlternatingRowBackground="#F0F7F4"
                              BorderBrush="#DEE2E6" BorderThickness="1" FontSize="12" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2D6A4F"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#1B4332"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="70"/>
                            <DataGridTextColumn Header="Credit" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Points" Binding="{Binding PointsDisplay}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Met">
                                                <Setter Property="Foreground" Value="#2D6A4F"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Achieved">
                                                <Setter Property="Foreground" Value="#2D6A4F"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Not Met">
                                                <Setter Property="Foreground" Value="#D62828"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Partial">
                                                <Setter Property="Foreground" Value="#FF9800"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Details" Binding="{Binding Description}" Width="250"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="By Category">
                    <TreeView x:Name="CategoryTreeView" FontSize="12" BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Credits}">
                                <TextBlock>
                                    <Run Text="{Binding Code}" FontWeight="Bold"/>
                                    <Run Text=" - "/>
                                    <Run Text="{Binding Name}"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding TotalPoints}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding MaxPoints}"/>
                                    <Run Text=" pts)"/>
                                </TextBlock>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Code}" Width="60" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Name}" Width="250"/>
                                            <TextBlock Text="{Binding PointsDisplay}" Width="60" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Status}" Width="100" Foreground="#6C757D"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </TabItem>

                <TabItem Header="Carbon Focus">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="LEED v5 Carbon Requirements" FontSize="16" FontWeight="SemiBold" Foreground="#2D6A4F" Margin="0,0,0,12"/>

                            <Border Background="#D8F3DC" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="IPp3: Carbon Assessment (Required)" FontWeight="SemiBold" FontSize="13" Foreground="#2D6A4F"/>
                                    <TextBlock x:Name="CarbonAssessmentStatus" Text="Status" Margin="0,4,0,0" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#D8F3DC" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="MRp2: Quantify and Assess Embodied Carbon (Required)" FontWeight="SemiBold" FontSize="13" Foreground="#2D6A4F"/>
                                    <TextBlock x:Name="EmbodiedCarbonStatus" Text="Status" Margin="0,4,0,0" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFF8E1" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="MRc2: Reduce Embodied Carbon (Up to 6 points)" FontWeight="SemiBold" FontSize="13" Foreground="#E65100"/>
                                    <TextBlock x:Name="ReduceEmbodiedStatus" Text="Status" Margin="0,4,0,0" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="LEED v5 emphasizes whole-building life cycle assessment and decarbonization."
                                       FontStyle="Italic" Foreground="#6C757D" Margin="0,16,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="USGBC LEED v5" Click="OpenUSGBC_Click" Style="{StaticResource GcPrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="Export Report" Click="ExportReport_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Close" Click="Close_Click" Style="{StaticResource GcSecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
