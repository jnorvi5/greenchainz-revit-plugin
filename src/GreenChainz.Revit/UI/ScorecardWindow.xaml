<Window x:Class="GreenChainz.Revit.UI.ScorecardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sustainability Scorecard - GreenChainz" Height="850" Width="1000"
        MinHeight="650" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="GradeBox" TargetType="Border">
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="8"/>
            </Style>
            <Style x:Key="MetricTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#6C757D"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            <Style x:Key="MetricValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
            <Style x:Key="MetricGrade" TargetType="TextBlock">
                <Setter Property="FontSize" Value="48"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Green Header Bar -->
        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sustainability Scorecard" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="ProjectNameText" Text="Project Name" FontSize="11" Foreground="#B7E4C7" Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Location Info -->
                <Border Grid.Column="1" Background="#1B4332" CornerRadius="6" Padding="12,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Location: " FontWeight="Bold" FontSize="11" Foreground="#B7E4C7"/>
                            <TextBlock x:Name="LocationText" Text="CA, West Coast" FontSize="11" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Grid: " FontSize="10" Foreground="#B7E4C7"/>
                            <TextBlock x:Name="GridIntensityText" Text="530 lbs CO2/MWh" FontSize="10" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Climate Zone: " FontSize="10" Foreground="#B7E4C7"/>
                            <TextBlock x:Name="ClimateZoneText" Text="3 - Warm" FontSize="10" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Overall Grade -->
                <Border x:Name="OverallGradeBorder" Style="{StaticResource GradeBox}" Background="#D8F3DC" HorizontalAlignment="Center" MinWidth="280" Margin="0,0,0,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="OVERALL GRADE" Style="{StaticResource MetricTitle}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="OverallGradeText" Text="A" Style="{StaticResource MetricGrade}" Foreground="#2D6A4F"/>
                        <TextBlock x:Name="OverallScoreText" Text="Score: 85/100" FontSize="14" HorizontalAlignment="Center" Foreground="#6C757D"/>
                        <Border Background="#FFF8E1" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
                            <TextBlock x:Name="GradeDisclaimerText" Text="Based on 5 of 12 materials with EPD data"
                                       FontSize="10" Foreground="#F57C00" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Three Key Metrics -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource GradeBox}" Background="White" BorderBrush="#DEE2E6" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="EPD COVERAGE" Style="{StaticResource MetricTitle}"/>
                            <TextBlock x:Name="EpdGradeText" Text="B" Style="{StaticResource MetricValue}" Foreground="#FF9800"/>
                            <TextBlock x:Name="EpdValueText" Text="65% Coverage" FontSize="14" Margin="0,4,0,0"/>
                            <TextBlock x:Name="EpdDetailText" Text="13 of 20 materials" FontSize="11" Foreground="#6C757D"/>
                            <TextBlock x:Name="EpdStatusText" Text="LEED Compliant" FontSize="11" Foreground="#2D6A4F" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="EpdActionText" Text="" FontSize="10" Foreground="#1565C0" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource GradeBox}" Background="White" BorderBrush="#DEE2E6" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="EMBODIED CARBON (GWP)" Style="{StaticResource MetricTitle}"/>
                            <TextBlock x:Name="GwpGradeText" Text="A" Style="{StaticResource MetricValue}" Foreground="#2D6A4F"/>
                            <TextBlock x:Name="GwpValueText" Text="125,000 kgCO2e" FontSize="14" Margin="0,4,0,0"/>
                            <TextBlock x:Name="GwpIntensityText" Text="45.2 kgCO2e/m2" FontSize="11" Foreground="#6C757D"/>
                            <TextBlock x:Name="GwpReductionText" Text="25% below baseline" FontSize="11" Foreground="#2D6A4F" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="GwpSourceText" Text="*Estimated from CLF baseline data" FontSize="9" Foreground="#6C757D" FontStyle="Italic" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource GradeBox}" Background="White" BorderBrush="#DEE2E6" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="VERIFICATION TIER" Style="{StaticResource MetricTitle}"/>
                            <TextBlock x:Name="TierText" Text="GOLD" Style="{StaticResource MetricValue}" Foreground="#FFC107"/>
                            <TextBlock x:Name="TierBreakdownText" Text="EPD Available" FontSize="14" Margin="0,4,0,0"/>
                            <TextBlock x:Name="TierDetailText" Text="P:2 | G:10 | S:5 | N:3" FontSize="11" Foreground="#6C757D"/>
                            <TextBlock Text="Third-Party Verified" FontSize="11" Foreground="#2D6A4F" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Data Quality Warning -->
                <Border x:Name="DataQualityPanel" Background="#FFF8E1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="!" FontSize="20" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="DataQualityTitle" Text="Limited EPD Data Available" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="DataQualityText" Text="Only 3 of 8 materials have verified EPD data."
                                       FontSize="11" Foreground="#6C757D" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Find EPD Materials" Click="FindEpdMaterials_Click"
                                Style="{StaticResource GcPrimaryButton}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Buy Clean Compliance -->
                <Border x:Name="BuyCleanPanel" Background="#D8F3DC" CornerRadius="6" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="BuyCleanTitleText" Text="Buy Clean California Act" FontWeight="SemiBold" FontSize="14" Foreground="#2D6A4F"/>
                            <TextBlock x:Name="BuyCleanStatusText" Text="COMPLIANT" FontSize="12" Foreground="#2D6A4F" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Concrete GWP" FontSize="11" Foreground="#6C757D"/>
                            <TextBlock x:Name="ConcreteGwpText" Text="320 / 380 kgCO2e/m3" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Steel GWP" FontSize="11" Foreground="#6C757D"/>
                            <TextBlock x:Name="SteelGwpText" Text="980 / 1100 kgCO2e/ton" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Material Breakdown -->
                <Border Background="White" CornerRadius="6" Padding="12" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Material Breakdown" Style="{StaticResource GcSectionHeader}" Margin="0"/>
                            <TextBlock Text=" - " Foreground="#6C757D" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MaterialLegendText" Text="[EPD] = Verified | [Est] = Estimated" FontSize="11" Foreground="#6C757D" VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" x:Name="MaterialsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DEE2E6"
                                  RowBackground="White" AlternatingRowBackground="#F0F7F4"
                                  BorderThickness="0" FontSize="12" HeadersVisibility="Column"
                                  MaxHeight="300">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D6A4F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="BorderBrush" Value="#1B4332"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="80"/>
                                <DataGridTextColumn Header="Qty (m3)" Binding="{Binding Quantity, StringFormat=N2}" Width="70"/>
                                <DataGridTextColumn Header="GWP" Binding="{Binding GwpDisplay}" Width="95"/>
                                <DataGridTextColumn Header="Total kgCO2e" Binding="{Binding TotalGwpDisplay}" Width="95"/>
                                <DataGridTemplateColumn Header="EPD" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EpdStatusIcon}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasEpd}" Value="True">
                                                                <Setter Property="Foreground" Value="#2D6A4F"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasEpd}" Value="False">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Tier" Binding="{Binding TierDisplay}" Width="65"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#D8F3DC" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                            <TextBlock x:Name="LeedPointsText" Text="Est. LEED Points: 4" FontWeight="SemiBold" Foreground="#2D6A4F" FontSize="12"/>
                        </Border>
                        <Border x:Name="RegionalPointsBorder" Background="#E8D8F3" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                            <TextBlock x:Name="RegionalPointsText" Text="Regional Bonus: +2" FontWeight="SemiBold" Foreground="#7B1FA2" FontSize="12"/>
                        </Border>
                        <Border x:Name="BuyCleanBorder" Background="#D8F3DC" CornerRadius="4" Padding="10,5">
                            <TextBlock x:Name="BuyCleanText" Text="Buy Clean: Compliant" FontWeight="SemiBold" Foreground="#2D6A4F" FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Export IFC" Click="ExportIfc_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Website" Click="OpenWebsite_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Export PDF" Click="ExportPdf_Click" Style="{StaticResource GcPrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Close" Click="Close_Click" Style="{StaticResource GcSecondaryButton}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
