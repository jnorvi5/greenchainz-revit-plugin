<Window x:Class="GreenChainz.Revit.UI.CreateRFQDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create RFQ - GreenChainz" Height="700" Width="600"
        MinHeight="500" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GreenChainz.Revit;component/Themes/GreenChainzTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Green Header Bar -->
        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,14">
            <TextBlock Text="Submit Request for Quote" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Project Info -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Project Name" Style="{StaticResource GcCaptionText}" Margin="0,0,0,4"/>
                    <TextBox Name="ProjectNameTextBox" Style="{StaticResource GcTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Delivery Date" Style="{StaticResource GcCaptionText}" Margin="0,0,0,4"/>
                    <DatePicker Name="DeliveryDatePicker" FontFamily="Segoe UI" FontSize="13" Padding="6"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Project Address" Style="{StaticResource GcCaptionText}" Margin="0,0,0,4"/>
                <TextBox Name="ProjectAddressTextBox" Style="{StaticResource GcTextBox}"/>
            </StackPanel>

            <TextBlock Grid.Row="2" Text="Materials from Model" Style="{StaticResource GcSectionHeader}"/>

            <DataGrid Name="MaterialsDataGrid" Grid.Row="3" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Margin="0,0,0,12" RowBackground="White" AlternatingRowBackground="#F0F7F4"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DEE2E6"
                      HeadersVisibility="Column" BorderBrush="#DEE2E6" BorderThickness="1" FontSize="12">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D6A4F"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#1B4332"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Material Name" Binding="{Binding MaterialName}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                <TextBlock Text="Special Instructions" Style="{StaticResource GcCaptionText}" Margin="0,0,0,4"/>
                <TextBox Name="SpecialInstructionsTextBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Style="{StaticResource GcTextBox}"/>
            </StackPanel>

            <TextBlock Grid.Row="5" Text="Matched Sustainable Suppliers" Style="{StaticResource GcSectionHeader}"/>

            <DataGrid Name="SuppliersDataGrid" Grid.Row="6" AutoGenerateColumns="False" CanUserAddRows="False"
                      Height="130" Margin="0,0,0,12" RowBackground="White" AlternatingRowBackground="#F0F7F4"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DEE2E6"
                      HeadersVisibility="Column" BorderBrush="#DEE2E6" BorderThickness="1" FontSize="12">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D6A4F"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#1B4332"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="35"/>
                    <DataGridTextColumn Header="Supplier" Binding="{Binding Name}" Width="160" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Score" Binding="{Binding SustainabilityScore}" Width="55" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Certifications" Binding="{Binding CertificationsDisplay}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="StatusText" Grid.Row="7" Style="{StaticResource GcStatusText}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="8">
                <Button Name="FindSuppliersButton" Content="Find Suppliers" Click="FindSuppliersButton_Click" Style="{StaticResource GcSecondaryButton}" Margin="0,0,8,0"/>
                <Button Name="SubmitButton" Content="Submit RFQ" Click="SubmitButton_Click" Style="{StaticResource GcPrimaryButton}" Margin="0,0,8,0"/>
                <Button Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Style="{StaticResource GcSecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
