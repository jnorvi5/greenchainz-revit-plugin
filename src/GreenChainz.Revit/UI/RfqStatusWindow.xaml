<Window x:Class="GreenChainz.Revit.UI.RfqStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RFQ Status & Messaging - GreenChainz" Height="600" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- RFQ List -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="Your RFQs" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox Name="RfqListBox" DisplayMemberPath="ProjectName" SelectionChanged="RfqListBox_SelectionChanged"/>
        </DockPanel>

        <!-- Messaging Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Name="ActiveRfqTitle" FontSize="16" FontWeight="Bold" Text="Select an RFQ to view messages"/>
                <TextBlock Name="SupplierName" FontSize="12" Foreground="Gray" Text=""/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F9F9F9" Padding="10">
                <ItemsControl Name="MessagesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5" Padding="10" CornerRadius="5" 
                                    Background="{Binding IsUser, Converter={StaticResource BooleanToColorConverter}}"
                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource BooleanToAlignmentConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="MessageInput" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0"/>
                <Button Name="SendButton" Grid.Column="1" Content="Send" Click="SendButton_Click" Padding="20,10" Background="#4CAF50" Foreground="White"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
